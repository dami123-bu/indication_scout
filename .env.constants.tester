# Tunable limits — small values for fast, cheap test runs.
# Usage: CONSTANTS_FILE=.env.constants.test pytest

# LLM token limits
LLM_MAX_TOKENS=1024
SMALL_LLM_MAX_TOKENS=512

# Base client
DEFAULT_TIMEOUT=30.0
DEFAULT_MAX_RETRIES=3

# Literature / RAG
LITERATURE_TOP_K=3
SEMANTIC_SEARCH_TOP_K=3
PUBMED_MAX_RESULTS=20
RAG_LLM_CONCURRENCY=4
RAG_PUBMED_CONCURRENCY=3
RAG_DISEASE_CONCURRENCY=4

# Clinical trials
CLINICAL_TRIALS_SEARCH_MAX=10
CLINICAL_TRIALS_WHITESPACE_EXACT_MAX=10
CLINICAL_TRIALS_WHITESPACE_INDICATION_MAX=20
CLINICAL_TRIALS_WHITESPACE_TOP_DRUGS=10
CLINICAL_TRIALS_LANDSCAPE_MAX_TRIALS=10
CLINICAL_TRIALS_TERMINATED_DRUG_PAGE_SIZE=10
CLINICAL_TRIALS_TERMINATED_INDICATION_MAX=10

# Mechanism
MECHANISM_SIGNAL_THRESHOLD=0.4
MECHANISM_ASSOCIATIONS_CAP=5

# Disease helper
DISEASE_PUBMED_MIN_RESULTS=1

# Open Targets
OPEN_TARGETS_PAGE_SIZE=100
OPEN_TARGETS_COMPETITOR_PREFETCH_MAX=10
OPEN_TARGETS_ASSOCIATION_MIN_SCORE=0.1
