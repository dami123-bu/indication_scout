# Tunable limits — integration tests (real APIs, modest call volumes).
# Loaded automatically by tests/integration/conftest.py.
# Override on the command line: CONSTANTS_FILE=.env.constants pytest tests/integration

# LLM token limits
LLM_MAX_TOKENS=4096
SMALL_LLM_MAX_TOKENS=1024

# Base client
DEFAULT_TIMEOUT=30.0
DEFAULT_MAX_RETRIES=3

# Literature / RAG
LITERATURE_TOP_K=15
SEMANTIC_SEARCH_TOP_K=5
PUBMED_MAX_RESULTS=200
PUBMED_SEARCH_DEFAULT_MAX_RESULTS=50
PUBMED_ESUMMARY_BATCH_SIZE=200
PUBMED_EFETCH_BATCH_SIZE=100
RAG_LLM_CONCURRENCY=4
RAG_PUBMED_CONCURRENCY=3
RAG_DISEASE_CONCURRENCY=4

# Clinical trials
CLINICAL_TRIALS_LANDSCAPE_MAX_TRIALS=50

# Mechanism
MECHANISM_SIGNAL_THRESHOLD=0.4
MECHANISM_ASSOCIATIONS_CAP=10

# Disease helper
DISEASE_PUBMED_MIN_RESULTS=3

# Open Targets
OPEN_TARGETS_PAGE_SIZE=500
OPEN_TARGETS_COMPETITOR_PREFETCH_MAX=40
OPEN_TARGETS_ASSOCIATION_MIN_SCORE=0.1
